{
  "schema": "src/graphql/**/*.schema.ts",
  "generates": {
    "src/graphql/generated/graphql.ts": {
      "plugins": [
        "typescript",
        "typescript-resolvers"
      ],
      "config": {
        "contextType": "../context.js#GraphQLContext",
        "useTypeImports": true
      }
    }
  }
}